{
  "expo": {
    "name": "ApolloClaim",
    "slug": "ApolloClaim",
    "owner": "rohitkc7",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "apolloclaim",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-camera",
        {
          "cameraPermission": "ApolloClaim needs camera access to photograph tyre defects."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ApolloClaim needs photo library access to attach images to claims."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ApolloClaim needs photo library access to save captured images.",
          "savePhotosPermission": "ApolloClaim needs permission to save photos to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rohitkc7.apolloclaim",
      "infoPlist": {
        "NSCameraUsageDescription": "ApolloClaim needs camera access to photograph tyre defects.",
        "NSMicrophoneUsageDescription": "ApolloClaim needs microphone access.",
        "NSPhotoLibraryUsageDescription": "ApolloClaim needs photo library access to attach images to claims.",
        "NSPhotoLibraryAddUsageDescription": "ApolloClaim needs permission to save photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.rohitkc7.apolloclaim",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "a0f4ea26-d1b0-418a-8240-8cf86b2407fd"
      }
    }
  }
}
